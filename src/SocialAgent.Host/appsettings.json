{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "SocialAgent": "Debug"
    }
  },
  "SocialAgent": {
    "PollingIntervalMinutes": 5,
    "DatabaseProvider": "Sqlite",
    "Providers": {
      "Mastodon": {
        "Enabled": false,
        "InstanceUrl": "https://mastodon.social",
        "AccessToken": ""
      },
      "Bluesky": {
        "Enabled": false,
        "ServiceUrl": "https://bsky.social",
        "Handle": "",
        "AppPassword": ""
      }
    }
  },
  "ConnectionStrings": {
    "SocialAgent": "Data Source=socialagent.db"
  }
}
